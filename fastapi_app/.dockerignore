# VCS
.git
.gitignore
.gitattributes

# Other build contexts and infra files (not used by app at runtime)
# - frontend builds via its own Dockerfile in the frontend-builder service
# - nginx config is mounted into the nginx container via a volume bind
frontend
nginx
docker-compose*.yml
Dockerfile
.dockerignore

# Runtime data — media is mounted as a docker volume at /app/media,
# so anything baked into the image at that path would be shadowed anyway
media
*.log

# Secrets — values arrive via `env_file: .env` at compose-time, injected
# as environment variables. The .env file itself does not need to be in
# the image and shouldn't be (would let anyone with `docker exec` read prod creds).
.env*

# Dev tooling and docs (not needed at runtime)
scripts
api_test.sh
README.md

# Python build/cache artifacts
__pycache__
**/__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
htmlcov
.venv
venv

# Editor / OS junk
.vscode
.idea
.DS_Store
Thumbs.db
*.swp
*.swo
