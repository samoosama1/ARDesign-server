POSTGRES_USER=myuser
POSTGRES_PASSWORD=
POSTGRES_DB=arpatentdb
POSTGRES_HOST=db
POSTGRES_PORT=5432
REDIS_URL=redis://redis:6379/0
MEDIA_ROOT=/app/media
# Name of the docker volume the worker mounts into converter containers.
# Must match the actual compose volume name: "<project>_<volume>".
# Prod project name is "arpatent-prod" (see top of docker-compose.prod.yml).
MEDIA_VOLUME_NAME=arpatent-prod_media_data
JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Set to the https URL ngrok gives you (or your domain for TLS setup).
CORS_ORIGINS=https://your-ngrok-subdomain.ngrok-free.app
DEBUG=false
# Image tag used by docker-compose.prod.yml for api and worker.
APP_VERSION=v0.1.0